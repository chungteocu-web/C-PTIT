#include <iostream>
#include <string>
#include <map>
#include <set>
#include <vector>
#include <algorithm>
#include <cstring>
using namespace std;
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        int n1, n2;
        cin >> n1 >> n2;
        vector<int> a(n1), b(n2), c;
        map<int, int> mp;
        for (int i = 0; i < n1; i++)
        {
            cin >> a[i];
            mp[a[i]]++;
        }
        for (int i = 0; i < n2; i++)
        {
            cin >> b[i];
        }
        for (int i = 0; i < n2; i++)
        {
            while (mp[b[i]] != 0)
            {
                c.push_back(b[i]);
                mp[b[i]]--;
            }
        }

        sort(a.begin(), a.end());
        for (int i = 0; i < n1; i++)
        {
            if (mp[a[i]] != 0)
            {
                c.push_back(a[i]);
            }
        }
        for (int i = 0; i < c.size(); i++)
        {
            cout << c[i] << " ";
        }
        cout << endl;
    }
}
