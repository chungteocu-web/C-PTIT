#include <iostream>
#include <string>
#include <vector>
#include <cstring>
using namespace std;
void nhan(string a, string b)
{
    vector<int> c(a.size() + b.size(), 0);
    for (int i = a.size() - 1; i >= 0; i--)
    {
        for (int j = b.size() - 1; j >= 0; j--)
        {
            int soht = i + j + 1, sonho = i + j;
            int tongnhan = (a[i] - '0') * (b[j] - '0'), tongso = (tongnhan + c[soht]);
            c[soht] = tongso % 10;
            c[sonho] += tongso / 10;
        }
    }
    int dem = 0;
    for (int i = 0; i < c.size(); i++)
    {
        if (c[i] == 0)
            dem++;
        else
            break;
    }
    for (int i = dem; i < c.size(); i++)
    {
        cout << c[i];
    }
    cout << endl;
}
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        string a, b;
        cin >> a >> b;
        nhan(a, b);
        cout << endl;
    }
    return 0;
}
