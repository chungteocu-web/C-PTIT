#include <iostream>
#include <algorithm>
#include <vector>
#include <set>
#include <map>
using namespace std;
int a, b;
vector<vector<char>> matran(25, vector<char>(25));
void xuly(int i, int j)
{
    matran[i][j] = 'C';
    if (i + 1 < a && matran[i + 1][j] == 'O')
        xuly(i + 1, j);
    if (i - 1 >= 0 && matran[i - 1][j] == 'O')
        xuly(i - 1, j);
    if (j - 1 >= 0 && matran[i][j - 1] == 'O')
        xuly(i, j - 1);
    if (j + 1 >= 0 && matran[i][j + 1] == 'O')
        xuly(i, j + 1);
}
int main()
{
    int m;
    cin >> m;
    while (m--)
    {

        cin >> a >> b;
        for (int i = 0; i < a; i++)
        {
            for (int j = 0; j < b; j++)
            {
                cin >> matran[i][j];
            }
        }
        for (int i = 0; i < a; i++)
        {
            for (int j = 0; j < b; j++)
            {
                if (i == 0 || j == 0 || i == a - 1 || j == b - 1)
                {
                    if (matran[i][j] == 'O')
                    {
                        xuly(i, j);
                    }
                }
            }
        }
        for (int i = 0; i < a; i++)
        {
            for (int j = 0; j < b; j++)
            {
                if (matran[i][j] == 'O')
                {
                    matran[i][j] = 'X';
                }
                else if (matran[i][j] == 'C')
                {
                    matran[i][j] = 'O';
                }
            }
        }
        for (int i = 0; i < a; i++)
        {
            for (int j = 0; j < b; j++)
            {
                cout << matran[i][j] << " ";
            }
            cout << endl;
        }
    }
}
