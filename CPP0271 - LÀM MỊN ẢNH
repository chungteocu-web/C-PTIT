#include <iostream>
#include <algorithm>
#include <vector>
#include <map>
#include <set>
using namespace std;
int main()
{
    int t;
    cin >> t;
    while (t--)
    {
        long long m, n, l, p = 0, q = 0;
        cin >> m >> n >> l;
        long long kernel = l * l;
        vector<vector<int>> a(m + 1, vector<int>(n + 1)), pre(m + 1, vector<int>(n + 1));
        for (int i = 1; i <= m; i++)
        {
            for (int j = 1; j <= n; j++)
            {
                cin >> a[i][j];
            }
        }
        for (int i = 1; i <= m; i++)
        {
            for (int j = 1; j <= n; j++)
            {
                pre[i][j] = pre[i][j - 1] + pre[i - 1][j] - pre[i - 1][j - 1] + a[i][j];
            }
        }
        for (int i = 1; i <= m - l + 1; i++)
        {
            for (int j = 1; j <= n - l + 1; j++)
            {
                int r2 = i + l - 1, c2 = j + l - 1;
                int sum = pre[r2][c2] - pre[r2][j - 1] - pre[i - 1][c2] + pre[i - 1][j - 1];
                cout << sum / kernel << " ";
            }
            cout << endl;
        }
    }
}
