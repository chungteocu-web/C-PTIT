#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        int n;
        cin >> n;
        vector<int> a(n), b(n, 1), c(n, 1);
        for (int &i : a)
        {
            cin >> i;
        }
        for (int i = 0; i < n; i++)
        {
            for (int j = 0; j < i; j++)
            {
                if (a[i] > a[j])
                {
                    b[i] = max(b[i], b[j] + 1);
                }
            }
        }
        for (int i = n - 1; i >= 0; i--)
        {
            for (int j = n - 1; j > i; j--)
            {
                if (a[i] > a[j])
                {
                    c[i] = max(c[i], c[j] + 1);
                }
            }
        }
        int maxx = 0;
        for (int i = 0; i < n; i++)
        {
            maxx = max(maxx, b[i] + c[i] - 1);
        }
        cout << maxx << endl;
    }
}
